{
  "name": "ai-test-kit",
  "version": "1.0.1",
  "description": "Test utilities for the AI SDK: mock models, content and stream-part builders, fully type-safe",
  "keywords": [],
  "license": "MIT",
  "author": "Chris Cook",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zirkelc/ai-test-kit.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./language": "./dist/language/index.mjs",
    "./ui": "./dist/ui/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "pnpm build",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "lint": "oxlint --fix",
    "lint:ci": "oxlint",
    "format": "oxfmt --write",
    "format:ci": "oxfmt --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.10",
    "@ai-sdk/provider-utils": "^4.0.27",
    "@arethetypeswrong/cli": "^0.18.2",
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/node": "^25.2.3",
    "ai": "^6.0.197",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.30.0",
    "oxlint": "^1.45.0",
    "oxlint-tsgolint": "^0.11.5",
    "pkg-pr-new": "^0.0.63",
    "publint": "^0.3.17",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@ai-sdk/provider": "^3.0.0",
    "@ai-sdk/provider-utils": "^4.0.0",
    "ai": "5.x || 6.x",
    "vitest": ">=3"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx}": [
      "pnpm lint",
      "pnpm format"
    ],
    "*.{json,jsonc}": [
      "pnpm format"
    ]
  },
  "packageManager": "pnpm@10.29.2"
}
