    "lint-staged": "^16.2.7",
    "oxfmt": "^0.30.0",
    "oxlint": "^1.45.0",
    "oxlint-tsgolint": "^0.11.5",
    "pkg-pr-new": "^0.0.63",
    "publint": "^0.3.17",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx}": [
      "pnpm lint",
      "pnpm format"
